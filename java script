// ============================ // ELEMENTS // ============================ const envelopeSection = document.getElementById("envelope-section"); const birthdayIntro = document.getElementById("birthday-intro"); const bookSection = document.getElementById("book-section"); const finalSection = document.getElementById("final-section"); const envelope = document.querySelector(".envelope"); const music = document.getElementById("bgMusic"); const pages = document.querySelectorAll(".page"); const nextBtn = document.getElementById("nextBtn"); const prevBtn = document.getElementById("prevBtn"); let currentPage = 0; // ============================ // ENVELOPE OPENING // ============================ function openEnvelope() { envelope.classList.add("open"); // Start music if (music) { music.play().catch(() => {}); } // Create burst petals for (let i = 0; i < 25; i++) { createPetalBurst(); } // Pop animation envelope.style.transform = "scale(1.15)"; setTimeout(() => { envelope.style.transform = "scale(1)"; }, 250); // Show birthday intro setTimeout(() => { envelopeSection.style.display = "none"; birthdayIntro.style.display = "flex"; birthdayIntro.animate( [ { opacity: 0, transform: "scale(.85)" }, { opacity: 1, transform: "scale(1)" } ], { duration: 1000, fill: "forwards" } ); }, 1700); // Show book setTimeout(() => { birthdayIntro.style.display = "none"; bookSection.style.display = "flex"; }, 5000); } // ============================ // PAGE SYSTEM // ============================ function showPage(index) { pages.forEach(page => { page.classList.remove("active-page"); }); pages[index].classList.add("active-page"); pages[index].animate( [ { opacity: 0, transform: "rotateY(-20deg)" }, { opacity: 1, transform: "rotateY(0deg)" } ], { duration: 700, fill: "forwards" } ); } nextBtn.addEventListener("click", () => { if (currentPage < pages.length - 1) { currentPage++; showPage(currentPage); } else { // Last page reached bookSection.style.display = "none"; finalSection.style.display = "block"; finalSection.animate( [ { opacity: 0 }, { opacity: 1 } ], { duration: 1200, fill: "forwards" } ); window.scrollTo({ top: 0, behavior: "smooth" }); } }); prevBtn.addEventListener("click", () => { if (currentPage > 0) { currentPage--; showPage(currentPage); } }); // ============================ // FALLING PETALS // ============================ const petalsContainer = document.querySelector(".petals-container"); function createPetal() { const petal = document.createElement("div"); petal.classList.add("petal"); petal.style.left = Math.random() * window.innerWidth + "px"; petal.style.animationDuration = (5 + Math.random() * 6) + "s"; petal.style.opacity = Math.random(); petal.style.transform = `rotate(${Math.random() * 360}deg)`; petalsContainer.appendChild(petal); setTimeout(() => { petal.remove(); }, 12000); } setInterval(createPetal, 350); // ============================ // BURST PETALS // ============================ function createPetalBurst() { const petal = document.createElement("div"); petal.classList.add("petal"); petal.style.left = window.innerWidth / 2 + "px"; petal.style.top = window.innerHeight / 2 + "px"; const x = (Math.random() - 0.5) * 700; const y = (Math.random() - 0.5) * 500; petal.animate( [ { transform: "translate(0,0) rotate(0deg)", opacity: 1 }, { transform: `translate(${x}px, ${y}px) rotate(720deg)`, opacity: 0 } ], { duration: 1800, easing: "ease-out" } ); document.body.appendChild(petal); setTimeout(() => { petal.remove(); }, 1800); } // ============================ // FLOATING HEARTS // ============================ const heartsContainer = document.querySelector(".hearts-container"); function createHeart() { const heart = document.createElement("div"); heart.classList.add("heart"); heart.innerHTML = "❤"; heart.style.left = Math.random() * 100 + "%"; heart.style.fontSize = (12 + Math.random() * 20) + "px"; heartsContainer.appendChild(heart); setTimeout(() => { heart.remove(); }, 7000); } setInterval(createHeart, 900); // ============================ // PHOTO GLOW EFFECT // ============================ const photoFrame = document.querySelector(".photo-frame"); if (photoFrame) { setInterval(() => { photoFrame.animate( [ { boxShadow: "0 0 20px rgba(255,255,255,.3)" }, { boxShadow: "0 0 45px rgba(255,255,255,.8)" }, { boxShadow: "0 0 20px rgba(255,255,255,.3)" } ], { duration: 3000 } ); }, 3000); } // ============================ // INITIAL PAGE // ============================ showPage(currentPage); // ============================ // SMALL STAR SPARKLES // ============================ function createSparkle() { const sparkle = document.createElement("div"); sparkle.style.position = "fixed"; sparkle.style.width = "4px"; sparkle.style.height = "4px"; sparkle.style.borderRadius = "50%"; sparkle.style.background = "white"; sparkle.style.left = Math.random() * window.innerWidth + "px"; sparkle.style.top = Math.random() * window.innerHeight + "px"; sparkle.style.opacity = ".9"; sparkle.style.pointerEvents = "none"; sparkle.style.zIndex = "1"; document.body.appendChild(sparkle); sparkle.animate( [ { opacity: 0 }, { opacity: 1 }, { opacity: 0 } ], { duration: 2500 } ); setTimeout(() => { sparkle.remove(); }, 2500); } setInterval(createSparkle, 500);
