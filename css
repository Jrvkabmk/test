/* ========================= */ /* FONTS & RESET */ /* ========================= */ *{ margin:0; padding:0; box-sizing:border-box; } html{ scroll-behavior:smooth; } body{ font-family:'Cormorant Garamond', serif; background:linear-gradient( 180deg, #2d000b, #4a0014, #67001f ); color:#fff; overflow-x:hidden; min-height:100vh; } /* ========================= */ /* MOON */ /* ========================= */ .moon{ position:fixed; top:40px; left:40px; width:140px; height:140px; border-radius:50%; background: radial-gradient( circle, #fffef7, #fff7d6 ); box-shadow: 0 0 40px rgba(255,255,255,.8), 0 0 80px rgba(255,255,255,.4), 0 0 120px rgba(255,255,255,.2); opacity:.9; z-index:-1; } /* ========================= */ /* FALLING PETALS */ /* ========================= */ .petals-container{ position:fixed; inset:0; pointer-events:none; overflow:hidden; z-index:2; } .petal{ position:absolute; width:15px; height:15px; background:#ffb6c1; border-radius: 0 100% 0 100%; opacity:.7; animation: fall linear forwards; } @keyframes fall{ from{ transform: translateY(-50px) rotate(0deg); } to{ transform: translateY(120vh) rotate(360deg); } } /* ========================= */ /* HEARTS */ /* ========================= */ .hearts-container{ position:fixed; inset:0; pointer-events:none; } .heart{ position:absolute; color:#ff5c8d; animation: floatHeart 7s linear forwards; } @keyframes floatHeart{ from{ opacity:1; transform: translateY(100vh) scale(0.5); } to{ opacity:0; transform: translateY(-20vh) scale(1.3); } } /* ========================= */ /* ENVELOPE SECTION */ /* ========================= */ #envelope-section{ min-height:100vh; display:flex; flex-direction:column; justify-content:center; align-items:center; text-align:center; } .intro-text h2{ font-family:'Great Vibes', cursive; font-size:3.5rem; margin-bottom:10px; } .intro-text p{ font-size:1.2rem; opacity:.85; } .envelope-wrapper{ margin-top:50px; cursor:pointer; transition:.4s; } .envelope-wrapper:hover{ transform:scale(1.05); } .envelope{ position:relative; width:320px; height:220px; background:#fff8f5; border-radius:8px; box-shadow: 0 20px 40px rgba(0,0,0,.35); } .envelope-flap{ position:absolute; width:100%; height:100%; background:#b50037; clip-path: polygon( 0 0, 100% 0, 50% 55% ); transform-origin:top; transition:1.2s; } .letter-inside{ position:absolute; width:90%; height:85%; left:5%; top:8%; background:white; border-radius:10px; display:flex; justify-content:center; align-items:center; font-size:4rem; } .envelope.open .envelope-flap{ transform: rotateX(180deg); } .click-text{ margin-top:25px; font-size:1.2rem; letter-spacing:3px; } /* ========================= */ /* BIRTHDAY INTRO */ /* ========================= */ #birthday-intro{ display:none; min-height:100vh; justify-content:center; align-items:center; } .birthday-card{ width:85%; max-width:900px; background:#fffaf6; color:#5a0018; border-radius:40px; padding:70px; text-align:center; box-shadow: 0 20px 50px rgba(0,0,0,.3); } .birthday-card h1{ font-family:'Great Vibes', cursive; font-size:5rem; line-height:1.3; } .birthday-subtitle{ margin-top:25px; font-size:1.5rem; } /* ========================= */ /* BOOK */ /* ========================= */ #book-section{ display:none; min-height:100vh; justify-content:center; align-items:center; padding:60px 20px; } .book-container{ width:100%; max-width:900px; } .book{ position:relative; height:600px; perspective:2000px; } .page{ position:absolute; width:100%; height:100%; background:#fffaf5; color:#5a0018; border-radius:20px; padding:60px; box-shadow: 0 20px 50px rgba(0,0,0,.3); display:none; transform-origin:left; } .active-page{ display:block; } .page-content{ height:100%; display:flex; flex-direction:column; } .page-content h2{ font-family:'Great Vibes', cursive; font-size:3.2rem; text-align:center; } .decorative-line{ width:200px; height:2px; margin:20px auto 40px; background: linear-gradient( to right, transparent, #b50037, transparent ); } .page-content p{ font-size:1.5rem; line-height:2; } /* ========================= */ /* BUTTONS */ /* ========================= */ .book-controls{ display:flex; justify-content:center; gap:20px; margin-top:40px; } .book-controls button{ padding: 14px 28px; border:none; border-radius:50px; background:#b50037; color:white; font-size:1rem; cursor:pointer; transition:.3s; } .book-controls button:hover{ transform:translateY(-3px); } /* ========================= */ /* FINAL SECTION */ /* ========================= */ #final-section{ display:none; min-height:100vh; padding:100px 20px; text-align:center; } .final-content h2{ font-family:'Great Vibes', cursive; font-size:4rem; margin-bottom:40px; } .photo-frame{ width:320px; height:420px; margin:auto; border:8px solid #fffaf5; border-radius:25px; overflow:hidden; box-shadow: 0 0 30px rgba(255,255,255,.4); } .photo-frame img{ width:100%; height:100%; object-fit:cover; } .admiration-text{ margin-top:30px; font-size:1.6rem; } /* ========================= */ /* CATS */ /* ========================= */ .cats-container{ margin-top:40px; display:flex; justify-content:center; gap:30px; flex-wrap:wrap; } .cat{ width:140px; transition:.4s; } .cat:hover{ transform: translateY(-10px) scale(1.05); } /* ========================= */ /* ENDING */ /* ========================= */ .ending-message{ margin-top:60px; } .ending-message h1{ font-family:'Great Vibes', cursive; font-size:5rem; margin-bottom:20px; } .ending-message p{ font-size:1.6rem; margin-bottom:30px; } .ending-message h3{ font-size:2rem; } /* ========================= */ /* MOBILE */ /* ========================= */ @media(max-width:768px){ .birthday-card h1{ font-size:3rem; } .page{ padding:30px; } .page-content h2{ font-size:2.4rem; } .page-content p{ font-size:1.2rem; } .photo-frame{ width:260px; height:340px; } .ending-message h1{ font-size:3rem; } }
